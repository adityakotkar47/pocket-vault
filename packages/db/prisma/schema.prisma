generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TxnType {
  DEBIT
  CREDIT
}

model Transaction {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  date           DateTime
  description    String
  amount         Decimal      @db.Decimal(14, 2)
  currency       String       @default("INR")
  type           TxnType
  balanceAfter   Decimal?     @db.Decimal(14, 2)
  category       String?
  rawText        String
  rawHash        String
  confidence     Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, rawHash])
  @@index([organizationId, createdAt, id])
  @@index([userId])
  @@map("transaction")
}
