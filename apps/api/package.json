{
  "name": "@pocketvault/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun run src/index.ts",
    "start:prod": "cd ../../packages/db && bun x prisma migrate deploy && cd - && (bun run src/seed.ts || echo 'Seed step failed, continuing') && bun run src/index.ts",
    "seed": "bun run src/seed.ts",
    "lint": "tsc --noEmit",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "dependencies": {
    "@pocketvault/db": "workspace:*",
    "better-auth": "latest",
    "hono": "latest",
    "hono-rate-limiter": "^0.5.3",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/jest": "^29",
    "@types/node": "latest",
    "cross-env": "^10.1.0",
    "jest": "^29",
    "ts-jest": "^29",
    "typescript": "^5"
  }
}
